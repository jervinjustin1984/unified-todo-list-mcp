# Supabase — Dashboard → Settings → API Keys
# https://supabase.com/dashboard/project/_/settings/api-keys
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Browser login + middleware — legacy "anon" (eyJ...) OR new "publishable" (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Server only (REST/MCP) — legacy "service_role" (eyJ...) OR new "secret" (sb_secret_...)
# Never put this in NEXT_PUBLIC_* or use sb_publishable_ here.
# line removed here to upload to github

# Optional middleware fallback (same value as NEXT_PUBLIC_SUPABASE_ANON_KEY)
# SUPABASE_ANON_KEY=your_anon_or_publishable_key
