# Supabase — Project Settings → API
# For Vercel: set ALL of these on the project, then redeploy (NEXT_PUBLIC_* must exist at build time).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# anon / publishable key (browser + middleware session)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Optional server-only alias (middleware fallback if NEXT_PUBLIC_* missing at build)
SUPABASE_ANON_KEY=your_anon_key

# service_role secret (REST/MCP server paths only — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
